# ──────────────────────────────────────────────────────────────
# Backups locais (dashboard.html.bak, _backup_*, etc.) — fica só
# na máquina, não polui o histórico do git.
# ──────────────────────────────────────────────────────────────
_backup_*
*.bak*

# ──────────────────────────────────────────────────────────────
# Scripts de dry-run/comparação (prefixo _) — uso pontual local.
# ──────────────────────────────────────────────────────────────
_compare_*.py
_dry_run_*.py
_gen_*.py
_build_*.py
_bp_*.py
_atualizar_*.py
_make_icons.py

